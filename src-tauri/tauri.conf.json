{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mhxy-bot-win10",
  "version": "0.4.0",
  "identifier": "cc.jtnet.mhxybotwin10",
  "build": {
    "frontendDist": "../app/ui"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "mhxy-bot-win10",
        "width": 1400,
        "height": 920,
        "resizable": true,
        "center": true,
        "minWidth": 1180,
        "minHeight": 760
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "icon": [
      "icons/app-icon.png",
      "icons/app-icon.ico",
      "icons/app-icon.icns"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false
      }
    }
  }
}
